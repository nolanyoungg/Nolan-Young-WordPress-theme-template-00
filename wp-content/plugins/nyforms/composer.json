{
  "name": "nolan-young/nyforms",
  "type": "wordpress-plugin",
  "description": "Development standards configuration for the NYforms WordPress plugin.",
  "license": "GPL-2.0-or-later",
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpunit/phpunit": "^9.6",
    "wp-coding-standards/wpcs": "^3.2"
  },
  "scripts": {
    "lint": "phpcs",
    "test": "phpunit",
    "make-pot": "wp i18n make-pot . languages/nyforms.pot --domain=nyforms --exclude=vendor,node_modules,tests"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
