{
  "$schema": "https://schemas.wp.org/wp/7.0/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1240px"
    },
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "ink",
          "name": "Ink",
          "color": "#172033"
        },
        {
          "slug": "navy",
          "name": "Navy",
          "color": "#0b2847"
        },
        {
          "slug": "blue",
          "name": "Blue",
          "color": "#1769e0"
        },
        {
          "slug": "sky",
          "name": "Sky",
          "color": "#dcecff"
        },
        {
          "slug": "mist",
          "name": "Mist",
          "color": "#f4f7fb"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        },
        {
          "slug": "success",
          "name": "Success",
          "color": "#176b45"
        },
        {
          "slug": "danger",
          "name": "Danger",
          "color": "#a92525"
        }
      ]
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vw"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "name": "2XS",
          "size": "0.5rem"
        },
        {
          "slug": "30",
          "name": "XS",
          "size": "0.75rem"
        },
        {
          "slug": "40",
          "name": "S",
          "size": "1rem"
        },
        {
          "slug": "50",
          "name": "M",
          "size": "1.5rem"
        },
        {
          "slug": "60",
          "name": "L",
          "size": "2rem"
        },
        {
          "slug": "70",
          "name": "XL",
          "size": "3rem"
        },
        {
          "slug": "80",
          "name": "2XL",
          "size": "4.5rem"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "customFontSize": false,
      "dropCap": false,
      "fontFamilies": [
        {
          "slug": "system",
          "name": "System Sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        },
        {
          "slug": "serif",
          "name": "Editorial Serif",
          "fontFamily": "Georgia, 'Times New Roman', serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.25rem"
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "clamp(1.75rem, 4vw, 2.75rem)"
        },
        {
          "slug": "display",
          "name": "Display",
          "size": "clamp(2.5rem, 7vw, 5.5rem)"
        }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "slug": "soft",
          "name": "Soft",
          "shadow": "0 18px 45px rgba(11, 40, 71, 0.12)"
        }
      ]
    },
    "custom": {
      "radius": {
        "small": "0.5rem",
        "medium": "0.875rem",
        "large": "1.5rem"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|white",
      "text": "var:preset|color|ink"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system",
      "fontSize": "var:preset|font-size|medium",
      "lineHeight": "1.65"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "0.65rem"
        },
        "color": {
          "background": "var:preset|color|blue",
          "text": "var:preset|color|white"
        },
        "spacing": {
          "padding": {
            "top": "0.8rem",
            "right": "1.25rem",
            "bottom": "0.8rem",
            "left": "1.25rem"
          }
        },
        "typography": {
          "fontWeight": "700"
        }
      },
      "heading": {
        "color": {
          "text": "var:preset|color|navy"
        },
        "typography": {
          "fontWeight": "750",
          "lineHeight": "1.12"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|blue"
        },
        "typography": {
          "textDecoration": "underline"
        }
      }
    },
    "blocks": {
      "core/image": {
        "border": {
          "radius": "0.875rem"
        }
      },
      "core/quote": {
        "border": {
          "left": {
            "color": "var:preset|color|blue",
            "width": "4px"
          }
        },
        "spacing": {
          "padding": {
            "left": "1.5rem"
          }
        }
      }
    }
  }
}
